<div class="flex items-center space-x-3 px-4 py-2 border-b border-gray-100 dark:border-gray-700">
    <div class="flex-1 min-w-0">
        <p class="text-xs text-gray-500">{{@transaction.gateway_code}}</p>
        <p class="text-xs text-gray-400">{{format-date @transaction.created_at format="MMM d, yyyy HH:mm"}}</p>
    </div>
    <div class="flex flex-col items-end">
        <span class="text-sm font-semibold text-gray-900 dark:text-white">{{@transaction.formatted_amount}}</span>
        <Badge @status={{@transaction.status}} @color={{@transaction.status_badge_color}}>{{@transaction.status}}</Badge>
    </div>
</div>
