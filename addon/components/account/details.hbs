<div class="p-4 space-y-4">
    <div class="grid grid-cols-2 gap-4">
        <div class="field-info-container">
            <label class="field-info-label">Account Name</label>
            <p class="field-info-value">{{@account.name}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Account Code</label>
            <p class="field-info-value font-mono">{{@account.code}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Type</label>
            <p class="field-info-value">{{@account.type_label}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Status</label>
            <Badge @status={{@account.status_label}} @color={{if @account.is_active "green" "gray"}}>{{@account.status_label}}</Badge>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Balance</label>
            <p class="field-info-value text-xl font-bold">{{@account.formatted_balance}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Currency</label>
            <p class="field-info-value">{{@account.currency}}</p>
        </div>
    </div>
    {{#if @account.description}}
        <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
            <label class="field-info-label">Description</label>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{{@account.description}}</p>
        </div>
    {{/if}}
</div>
