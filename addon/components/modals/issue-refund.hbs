<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container">
        {{#let @options.invoice @options.summary as |invoice summary|}}
            <div class="flex items-center justify-between mb-4 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg">
                <div class="flex flex-col">
                    <span class="text-sm font-semibold text-gray-900 dark:text-white">{{n-a invoice.number}}</span>
                    <span class="text-xs text-gray-500">{{n-a invoice.customerName}}</span>
                </div>
                <div class="flex flex-col items-end">
                    <span class="text-sm font-bold text-gray-900 dark:text-white">
                        {{format-currency summary.total_amount summary.currency}}
                    </span>
                    <span class="text-xs text-gray-500">
                        Remaining refundable:
                        {{format-currency summary.remaining_refundable_amount summary.currency}}
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="rounded-md border border-gray-200 dark:border-gray-700 p-3">
                    <div class="text-xs text-gray-500">Paid</div>
                    <div class="text-sm font-semibold text-gray-900 dark:text-white">{{format-currency summary.amount_paid summary.currency}}</div>
                </div>
                <div class="rounded-md border border-gray-200 dark:border-gray-700 p-3">
                    <div class="text-xs text-gray-500">Refunded</div>
                    <div class="text-sm font-semibold text-gray-900 dark:text-white">{{format-currency summary.refunded_amount summary.currency}}</div>
                </div>
                <div class="rounded-md border border-gray-200 dark:border-gray-700 p-3">
                    <div class="text-xs text-gray-500">Available</div>
                    <div class="text-sm font-semibold text-gray-900 dark:text-white">{{format-currency summary.remaining_refundable_amount summary.currency}}</div>
                </div>
            </div>

            <InputGroup @name="Payment" @helpText="Refunds are issued against the original successful gateway payment.">
                <Select
                    class="w-full"
                    @value={{this.selectedGatewayTransactionId}}
                    @options={{@options.refundOptions}}
                    @optionLabel="label"
                    @optionValue="gateway_transaction_id"
                    @onChange={{this.selectGatewayTransaction}}
                    @placeholder="Select payment..."
                />
            </InputGroup>

            {{#if this.selectedOption}}
                <div class="mb-4 rounded-md border border-gray-200 dark:border-gray-700 p-3 text-xs text-gray-600 dark:text-gray-300">
                    <div class="flex items-center justify-between">
                        <span>{{n-a this.selectedOption.gateway.name}}</span>
                        <span>{{format-currency this.selectedOption.refundable_amount this.selectedOption.currency}}</span>
                    </div>
                    <div class="mt-1 text-gray-500">
                        Reference:
                        {{n-a this.selectedOption.gateway_transaction_id}}
                    </div>
                </div>
            {{/if}}

            <InputGroup @name="Refund Type" @helpText="Use full for the selected payment's remaining refundable amount, or custom for a partial refund.">
                <Select
                    class="w-full"
                    @value={{this.refundMode}}
                    @options={{this.refundModes}}
                    @optionLabel="label"
                    @optionValue="value"
                    @onChange={{this.setRefundMode}}
                />
            </InputGroup>

            <InputGroup @name="Amount" @helpText="The amount cannot exceed the remaining refundable amount.">
                <MoneyInput class="w-full" @value={{this.amount}} @currency={{summary.currency}} @onChange={{this.setAmount}} disabled={{not this.isCustomRefund}} />
            </InputGroup>

            <InputGroup @name="Reason" @helpText="Optional note recorded with the gateway refund and Ledger reversal.">
                <Textarea @value={{this.reason}} class="w-full form-input" rows="3" placeholder="Reason for refund" {{on "input" this.setReason}} />
            </InputGroup>

            {{#if this.requiresCustomerAction}}
                <div class="rounded-md border border-blue-200 bg-blue-50 p-3 text-sm text-blue-800 dark:border-blue-700 dark:bg-blue-900 dark:text-blue-100">
                    GNU Taler may return a refund URI. Share it with the customer so they can open it with their Taler wallet and accept the refund.
                </div>
            {{/if}}
        {{/let}}
    </div>
</Modal::Default>
