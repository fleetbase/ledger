<div class="flex items-center space-x-3 px-4 py-2 border-b border-gray-100 dark:border-gray-700">
    <div class="flex-1 min-w-0">
        <p class="text-xs text-gray-500">{{@gateway.driver_label}}</p>
        <p class="text-xs text-gray-400 capitalize">{{@gateway.environment}}</p>
    </div>
    <div class="flex flex-col items-end space-y-1">
        {{#if @gateway.is_default}}
            <Badge @color="blue">Default</Badge>
        {{/if}}
        <Badge @status={{@gateway.status_label}} @color={{if @gateway.is_active "green" "gray"}}>{{@gateway.status_label}}</Badge>
    </div>
</div>
