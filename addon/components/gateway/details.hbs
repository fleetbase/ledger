<div class="p-4 space-y-4">
    <div class="grid grid-cols-2 gap-4">
        <div class="field-info-container">
            <label class="field-info-label">Gateway Name</label>
            <p class="field-info-value">{{@gateway.name}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Driver</label>
            <p class="field-info-value">{{@gateway.driver_label}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Environment</label>
            <Badge @color={{if (eq @gateway.environment "live") "green" "yellow"}}>{{@gateway.environment}}</Badge>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Status</label>
            <Badge @status={{@gateway.status_label}} @color={{if @gateway.is_active "green" "gray"}}>{{@gateway.status_label}}</Badge>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Default Gateway</label>
            <p class="field-info-value">{{if @gateway.is_default "Yes" "No"}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Webhook URL</label>
            <p class="field-info-value font-mono text-xs break-all">{{@gateway.webhook_url}}</p>
        </div>
    </div>

    {{#if @gateway.capabilities}}
        <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
            <h4 class="text-xs font-semibold text-gray-500 uppercase mb-3">Capabilities</h4>
            <div class="flex flex-wrap gap-2">
                {{#each @gateway.capabilities as |cap|}}
                    <Badge @color="blue">{{cap}}</Badge>
                {{/each}}
            </div>
        </div>
    {{/if}}
</div>
