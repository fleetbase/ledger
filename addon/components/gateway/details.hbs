<div class="flex flex-col gap-4" ...attributes>
    {{#if this.showOverview}}
        <section class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
            {{#each this.readinessItems as |item|}}
                <div class="rounded-md border border-gray-200 bg-white p-3 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    <div class="flex items-start justify-between gap-2">
                        <div class="min-w-0">
                            <div class="truncate text-[10px] font-bold uppercase text-gray-500 dark:text-gray-400">{{item.label}}</div>
                            <div class="mt-2 truncate text-sm font-semibold text-gray-900 dark:text-gray-50">{{titleize item.status}}</div>
                        </div>
                        <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-200">
                            <FaIcon @icon={{item.icon}} />
                        </div>
                    </div>
                </div>
            {{/each}}
        </section>
    {{/if}}

    {{#if (or this.showOverview this.showSetup)}}
        <section class="grid grid-cols-1 gap-4 xl:grid-cols-[minmax(0,1fr)_24rem]">
        <div class="rounded-md border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
                <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100">Gateway Operations</h2>
                <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-300">How this gateway appears to customers and how Ledger receives operational events.</p>
            </div>
            <div class="grid grid-cols-1 gap-4 p-4 lg:grid-cols-2">
                <div class="rounded-md border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-900">
                    <div class="text-xs font-bold uppercase text-gray-500 dark:text-gray-400">Customer Payment Preview</div>
                    <div class="mt-3 rounded-md border border-gray-200 bg-white p-3 dark:border-gray-700 dark:bg-gray-800">
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <div class="text-sm font-semibold text-gray-900 dark:text-gray-100">{{this.driverLabel}}</div>
                                <div class="mt-1 text-xs text-gray-500 dark:text-gray-300">{{this.checkoutPreviewLabel}}</div>
                            </div>
                            <Badge @status={{@resource.status}} @hideStatusDot={{true}}>{{titleize @resource.status}}</Badge>
                        </div>
                        <div class="mt-3 flex h-16 items-center justify-center rounded-md border border-dashed border-gray-300 text-xs text-gray-500 dark:border-gray-600 dark:text-gray-400">
                            {{#if this.isTaler}}
                                QR code / wallet redirect appears here on public invoices
                            {{else if (eq @resource.driver "cash")}}
                                Operator records the payment manually
                            {{else}}
                                Customer selects this gateway on public invoices
                            {{/if}}
                        </div>
                    </div>
                </div>

                <div class="rounded-md border border-gray-200 bg-gray-50 p-3 dark:border-gray-700 dark:bg-gray-900">
                    <div class="text-xs font-bold uppercase text-gray-500 dark:text-gray-400">Integration</div>
                    <div class="mt-3 space-y-3 text-xs">
                        <div>
                            <div class="font-semibold text-gray-700 dark:text-gray-200">System Webhook URL</div>
                            <div class="mt-1 flex items-start gap-2 rounded-md bg-white p-2 font-mono text-[11px] text-gray-600 dark:bg-gray-800 dark:text-gray-300">
                                <span class="min-w-0 flex-1 break-all">{{n-a @resource.system_webhook_url}}</span>
                                {{#if @resource.system_webhook_url}}
                                    <ClickToCopy @value={{@resource.system_webhook_url}} @buttonText="Copy" />
                                {{/if}}
                            </div>
                        </div>
                        <div>
                            <div class="font-semibold text-gray-700 dark:text-gray-200">Capabilities</div>
                            <div class="mt-1 flex flex-wrap gap-1">
                                {{#each @resource.capabilities as |capability|}}
                                    <Badge @color="blue">{{capability}}</Badge>
                                {{else}}
                                    <Badge @color="gray">Manual</Badge>
                                {{/each}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <aside class="rounded-md border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
                <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100">Operational Health</h2>
                <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-300">Recent gateway events and reconciliation signals.</p>
            </div>
            <div class="space-y-3 p-4 text-xs">
                <div class="flex items-center justify-between gap-3">
                    <span class="text-gray-500 dark:text-gray-400">Last webhook</span>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{{n-a this.lastWebhookAt}}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-gray-500 dark:text-gray-400">Last payment</span>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{{n-a this.lastPaymentAt}}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-gray-500 dark:text-gray-400">Last refund</span>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{{n-a this.lastRefundAt}}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-gray-500 dark:text-gray-400">Last settlement</span>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{{n-a this.lastSettlementAt}}</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                    <span class="text-gray-500 dark:text-gray-400">Reconciliation</span>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{{n-a this.reconciliationStatus}}</span>
                </div>
            </div>
        </aside>
        </section>
    {{/if}}

    {{#if (and this.isTaler (or this.showOverview this.showDiagnostics))}}
        <section class="rounded-md border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
                <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100">GNU Taler Diagnostics</h2>
                <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-300">Provision webhooks, create sandbox orders, and verify credential health for this Taler gateway.</p>
            </div>
            <div class="space-y-4 p-4">
                <div class="flex flex-wrap items-center gap-2">
                    <Button @type="secondary" @icon={{if this.testCredentials.isRunning "spinner" "check-circle"}} @iconSpin={{this.testCredentials.isRunning}} @text="Test Credentials" @onClick={{perform this.testCredentials}} />
                    <Button @type="secondary" @icon={{if this.registerWebhook.isRunning "spinner" "link"}} @iconSpin={{this.registerWebhook.isRunning}} @text="Register Webhook" @onClick={{perform this.registerWebhook}} />
                    <Button @type="secondary" @icon={{if this.createTestOrder.isRunning "spinner" "flask"}} @iconSpin={{this.createTestOrder.isRunning}} @text="Create Test Order" @onClick={{perform this.createTestOrder}} />
                    <Button @type="secondary" @icon={{if this.loadDiagnostics.isRunning "spinner" "rotate"}} @iconSpin={{this.loadDiagnostics.isRunning}} @text="Refresh" @onClick={{perform this.loadDiagnostics}} />
                </div>

                {{#if this.lastActionResult}}
                    <div class="rounded-md border border-gray-200 bg-gray-50 p-3 text-xs dark:border-gray-700 dark:bg-gray-900">
                        <div class="flex flex-wrap items-center gap-2">
                            <Badge @status={{this.lastActionResult.status}}>{{titleize this.lastActionResult.status}}</Badge>
                            <span class="text-gray-700 dark:text-gray-200">{{this.lastActionResult.message}}</span>
                        </div>
                        {{#if this.lastActionResult.data.taler_pay_uri}}
                            <div class="mt-2 break-all font-mono text-[11px] text-gray-500 dark:text-gray-300">{{this.lastActionResult.data.taler_pay_uri}}</div>
                        {{/if}}
                    </div>
                {{/if}}
            </div>
        </section>
    {{/if}}

    {{#if this.showSetup}}
        <section class="rounded-md border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="border-b border-gray-200 px-4 py-3 dark:border-gray-700">
                <h2 class="text-sm font-bold text-gray-900 dark:text-gray-100">Record Info</h2>
            </div>
            <div class="grid grid-cols-1 gap-3 p-4 text-xs md:grid-cols-3">
                <div>
                    <div class="text-gray-500 dark:text-gray-400">Internal ID</div>
                    <div class="mt-1 font-mono text-gray-900 dark:text-gray-100">{{n-a @resource.public_id}}</div>
                </div>
                <div>
                    <div class="text-gray-500 dark:text-gray-400">Created</div>
                    <div class="mt-1 text-gray-900 dark:text-gray-100">{{n-a @resource.createdAt}}</div>
                </div>
                <div>
                    <div class="text-gray-500 dark:text-gray-400">Updated</div>
                    <div class="mt-1 text-gray-900 dark:text-gray-100">{{n-a @resource.updatedAt}}</div>
                </div>
            </div>
        </section>
    {{/if}}
</div>
