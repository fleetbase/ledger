<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Recent Journal Entries</h3>
    <div class="space-y-2">
        {{#each @entries as |entry|}}
            <div class="flex items-center justify-between py-2 border-b border-gray-100 dark:border-gray-700 last:border-0">
                <div class="flex flex-col">
                    <span class="text-xs font-medium text-gray-700 dark:text-gray-300">{{entry.description}}</span>
                    <span class="text-xs text-gray-400">DR: {{entry.debit_account_name}} / CR: {{entry.credit_account_name}}</span>
                </div>
                <div class="flex flex-col items-end">
                    <span class="text-xs font-medium text-gray-900 dark:text-white">{{entry.formatted_amount}}</span>
                    <span class="text-xs text-gray-400">{{format-date entry.date format="MMM d"}}</span>
                </div>
            </div>
        {{else}}
            <p class="text-xs text-gray-400">No recent journal entries</p>
        {{/each}}
    </div>
</div>
