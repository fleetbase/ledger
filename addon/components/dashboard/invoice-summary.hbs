<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
    <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Invoices</h3>
    <div class="space-y-2">
        {{#each-in @data as |status count|}}
            <div class="flex items-center justify-between">
                <span class="text-xs text-gray-500 capitalize">{{status}}</span>
                <Badge @status={{status}}>{{count}}</Badge>
            </div>
        {{else}}
            <p class="text-xs text-gray-400">No invoice data</p>
        {{/each-in}}
    </div>
</div>
