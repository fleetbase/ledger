<div class="space-y-4">
    <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Accounts Receivable Aging</h2>
        {{#if @data.as_of}}
            <span class="text-sm text-gray-500">As of {{format-date-fns @data.as_of "MMMM d, yyyy"}}</span>
        {{/if}}
    </div>

    {{! Summary buckets }}
    <div class="grid grid-cols-5 gap-3">
        {{#each @data.buckets as |bucket|}}
            <div class="bg-gray-50 dark:bg-gray-700 rounded p-3 text-center">
                <p class="text-xs text-gray-500 mb-1">{{bucket.label}}</p>
                <p class="text-sm font-bold {{if (gt bucket.total 0) "text-red-600" "text-gray-400"}}">{{format-currency bucket.total @data.currency}}</p>
                <p class="text-xs text-gray-400">{{bucket.count}} invoice(s)</p>
            </div>
        {{/each}}
    </div>

    {{! Detail rows }}
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700">
                <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Invoice</th>
                <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Customer</th>
                <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Due Date</th>
                <th class="text-right py-2 text-xs font-medium text-gray-500 uppercase">Balance</th>
                <th class="text-right py-2 text-xs font-medium text-gray-500 uppercase">Days Overdue</th>
                <th class="text-left py-2 text-xs font-medium text-gray-500 uppercase">Bucket</th>
            </tr>
        </thead>
        <tbody>
            {{#each @data.invoices as |row|}}
                <tr class="border-b border-gray-100 dark:border-gray-700 last:border-0">
                    <td class="py-2 text-blue-600 text-xs font-mono">{{row.number}}</td>
                    <td class="py-2 text-gray-700 dark:text-gray-300 text-xs">{{row.customer_name}}</td>
                    <td class="py-2 text-gray-600 text-xs">{{format-date-fns row.due_date "MMM d, yyyy"}}</td>
                    <td class="py-2 text-right font-medium text-xs text-red-600">{{format-currency row.balance @data.currency}}</td>
                    <td class="py-2 text-right text-xs {{if (gt row.days_overdue 60) "text-red-600 font-semibold" "text-gray-600"}}">{{row.days_overdue}}</td>
                    <td class="py-2 text-xs">
                        <Badge @color={{if (gt row.days_overdue 60) "red" (if (gt row.days_overdue 30) "yellow" "gray")}}>{{row.bucket_label}}</Badge>
                    </td>
                </tr>
            {{else}}
                <tr>
                    <td colspan="6" class="py-4 text-center text-gray-400 text-xs">No outstanding receivables</td>
                </tr>
            {{/each}}
        </tbody>
        {{#if @data.total_outstanding}}
            <tfoot>
                <tr class="border-t-2 border-gray-300">
                    <td colspan="3" class="py-2 font-semibold text-gray-900 dark:text-white">Total Outstanding</td>
                    <td class="py-2 text-right font-bold text-red-600">{{format-currency @data.total_outstanding @data.currency}}</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        {{/if}}
    </table>
</div>
