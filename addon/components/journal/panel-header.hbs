<div class="flex items-center space-x-3 px-4 py-2 border-b border-gray-100 dark:border-gray-700">
    <div class="flex-1 min-w-0">
        <p class="text-xs text-gray-500">{{@entry.type_label}}</p>
        <p class="text-xs text-gray-400">{{format-date @entry.date format="MMM d, yyyy"}}</p>
    </div>
    <div class="flex flex-col items-end">
        <span class="text-sm font-semibold text-gray-900 dark:text-white">{{@entry.formatted_amount}}</span>
        <Badge @status={{@entry.entry_source}} @color={{if @entry.is_system_entry "blue" "gray"}}>{{@entry.entry_source}}</Badge>
    </div>
</div>
