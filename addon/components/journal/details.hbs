<div class="p-4 space-y-4">
    <div class="grid grid-cols-2 gap-4">
        <div class="field-info-container">
            <label class="field-info-label">Entry Number</label>
            <p class="field-info-value">{{@entry.number}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Type</label>
            <p class="field-info-value">{{@entry.type_label}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Date</label>
            <p class="field-info-value">{{format-date-fns @entry.date "MMM d, yyyy"}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Source</label>
            <Badge @status={{@entry.entry_source}} @color={{if @entry.is_system_entry "blue" "gray"}}>{{@entry.entry_source}}</Badge>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Amount</label>
            <p class="field-info-value font-semibold">{{@entry.formatted_amount}}</p>
        </div>
        <div class="field-info-container">
            <label class="field-info-label">Currency</label>
            <p class="field-info-value">{{@entry.currency}}</p>
        </div>
    </div>

    <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
        <h4 class="text-xs font-semibold text-gray-500 uppercase mb-3">Double-Entry</h4>
        <div class="grid grid-cols-2 gap-4">
            <div class="bg-green-50 dark:bg-green-900/20 rounded p-3">
                <p class="text-xs font-medium text-green-700 dark:text-green-400 uppercase mb-1">Debit</p>
                <p class="text-sm font-semibold text-gray-900 dark:text-white">{{@entry.debit_account_name}}</p>
                <p class="text-xs text-gray-500">{{@entry.debit_account_code}}</p>
            </div>
            <div class="bg-blue-50 dark:bg-blue-900/20 rounded p-3">
                <p class="text-xs font-medium text-blue-700 dark:text-blue-400 uppercase mb-1">Credit</p>
                <p class="text-sm font-semibold text-gray-900 dark:text-white">{{@entry.credit_account_name}}</p>
                <p class="text-xs text-gray-500">{{@entry.credit_account_code}}</p>
            </div>
        </div>
    </div>

    {{#if @entry.description}}
        <div class="border-t border-gray-100 dark:border-gray-700 pt-4">
            <label class="field-info-label">Description</label>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{{@entry.description}}</p>
        </div>
    {{/if}}
</div>
