<div class="invoice-line-items" ...attributes>
    <div class="overflow-x-auto">
        <table class="w-full text-xs">
            <thead>
                <tr class="border-b border-gray-200 dark:border-gray-700 text-[11px] uppercase tracking-wide text-gray-500 font-semibold">
                    <th class="py-2 pr-2 text-left">Description</th>
                    <th class="py-2 px-2 text-right w-20">Qty</th>
                    <th class="py-2 px-2 text-right w-36">Unit Price</th>
                    <th class="py-2 px-2 text-right w-24">Tax %</th>
                    <th class="py-2 pl-2 text-right w-36">Amount</th>
                    {{#unless @disabled}}
                        <th class="py-2 pl-2 w-8"></th>
                    {{/unless}}
                </tr>
            </thead>
            <tbody>
                {{#each this.items key="_tmpId" as |item|}}
                    <tr class="border-b border-gray-100 dark:border-gray-800">

                        {{! Description }}
                        <td class="py-1 pr-2">
                            <input
                                type="text"
                                value={{item.description}}
                                class="w-full form-input text-xs"
                                placeholder="Item description"
                                disabled={{@disabled}}
                                {{on "input" (fn this.updateDescription item)}}
                            />
                        </td>

                        {{! Quantity }}
                        <td class="py-1 px-2">
                            <input
                                type="number"
                                value={{item.quantity}}
                                min="1"
                                step="1"
                                class="w-full form-input text-xs text-right"
                                disabled={{@disabled}}
                                {{on "change" (fn this.updateQuantity item)}}
                            />
                        </td>

                        {{!
                            Unit Price — plain <input type="number"> showing dollar value (cents / 100).
                            We intentionally avoid MoneyInput here because its AutoNumeric integration
                            fires rawValueModified on every programmatic @value update, creating a
                            feedback loop when unit_price is @tracked.
                        }}
                        <td class="py-1 px-2">
                            <input
                                type="number"
                                value={{item.unitPriceDollars}}
                                min="0"
                                step="0.01"
                                class="w-full form-input text-xs text-right"
                                placeholder="0.00"
                                disabled={{@disabled}}
                                {{on "change" (fn this.updateUnitPrice item)}}
                            />
                        </td>

                        {{! Tax Rate % }}
                        <td class="py-1 px-2">
                            <input
                                type="number"
                                value={{item.tax_rate}}
                                min="0"
                                max="100"
                                step="0.01"
                                class="w-full form-input text-xs text-right"
                                placeholder="0"
                                disabled={{@disabled}}
                                {{on "change" (fn this.updateTaxRate item)}}
                            />
                        </td>

                        {{! Amount — read-only getter, updates automatically }}
                        <td class="py-1 pl-2 text-right font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap">
                            {{format-currency item.amount @currency}}
                        </td>

                        {{! Remove button }}
                        {{#unless @disabled}}
                            <td class="py-1 pl-2 text-center">
                                <button
                                    type="button"
                                    class="text-red-400 hover:text-red-600 transition-colors"
                                    {{on "click" (fn this.removeItem item)}}
                                >
                                    <FaIcon @icon="times" @size="xs" />
                                </button>
                            </td>
                        {{/unless}}
                    </tr>
                {{/each}}

                {{#if (eq this.items.length 0)}}
                    <tr>
                        <td colspan={{if @disabled 5 6}} class="py-4 text-center text-gray-400 text-xs italic">
                            No line items yet.
                            {{#unless @disabled}}
                                <button type="button" class="text-blue-500 hover:underline ml-1" {{on "click" this.addItem}}>
                                    Add one
                                </button>
                            {{/unless}}
                        </td>
                    </tr>
                {{/if}}
            </tbody>

            {{! Totals footer — all three are getters that update automatically }}
            <tfoot class="border-t border-gray-200 dark:border-gray-700">
                <tr class="text-xs text-gray-600 dark:text-gray-400">
                    <td colspan={{if @disabled 3 4}} class="pt-2 text-right pr-2 text-[11px] uppercase tracking-wide font-semibold">Subtotal</td>
                    <td class="pt-2 pl-2 text-right font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap">
                        {{format-currency this.subtotal @currency}}
                    </td>
                    {{#unless @disabled}}<td></td>{{/unless}}
                </tr>
                <tr class="text-xs text-gray-600 dark:text-gray-400">
                    <td colspan={{if @disabled 3 4}} class="pt-1 text-right pr-2 text-[11px] uppercase tracking-wide font-semibold">Tax</td>
                    <td class="pt-1 pl-2 text-right font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap">
                        {{format-currency this.tax @currency}}
                    </td>
                    {{#unless @disabled}}<td></td>{{/unless}}
                </tr>
                <tr class="text-xs">
                    <td colspan={{if @disabled 3 4}} class="pt-1 pb-2 text-right pr-2 text-[11px] uppercase tracking-wide font-bold text-gray-800 dark:text-gray-100">Total</td>
                    <td class="pt-1 pb-2 pl-2 text-right font-bold text-gray-800 dark:text-gray-100 whitespace-nowrap">
                        {{format-currency this.total @currency}}
                    </td>
                    {{#unless @disabled}}<td></td>{{/unless}}
                </tr>
            </tfoot>
        </table>
    </div>

    {{#unless @disabled}}
        <div class="mt-2">
            <button
                type="button"
                class="flex items-center gap-1 text-xs text-blue-500 hover:text-blue-700 transition-colors"
                {{on "click" this.addItem}}
            >
                <FaIcon @icon="plus" @size="xs" />
                Add line item
            </button>
        </div>
    {{/unless}}
</div>
