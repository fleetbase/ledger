<div class="flex items-center space-x-3 px-4 py-2 border-b border-gray-100 dark:border-gray-700">
    <div class="flex-1 min-w-0">
        <p class="text-xs text-gray-500">{{@invoice.customer_name}}</p>
        <p class="text-xs text-gray-400">Due {{@invoice.dueDate}}</p>
    </div>
    <div class="flex flex-col items-end">
        <span class="text-sm font-semibold text-gray-900 dark:text-white">{{@invoice.formatted_total}}</span>
        <Badge @status={{@invoice.status}} @color={{@invoice.status_badge_color}}>{{@invoice.status}}</Badge>
    </div>
</div>
