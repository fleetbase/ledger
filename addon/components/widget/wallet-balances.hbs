<div class="flex flex-col" ...attributes>
    <div class="flex flex-row items-center justify-between px-4 py-2 border dark:border-gray-700 border-gray-200 dark:bg-gray-800 bg-gray-50 rounded-t-lg shadow-sm">
        <span class="text-base font-bold text-black dark:text-gray-100">Wallet Balances</span>
    </div>
    <div class="border-x border-b dark:border-gray-700 border-gray-200 rounded-b-lg shadow-sm p-4 space-y-2 bg-white dark:bg-gray-900">
        {{#if this.loadData.isRunning}}
            <div class="flex items-center justify-center py-6"><Spinner /></div>
        {{else if this.totals}}
            {{#each-in this.totals as |currency total|}}
                <div class="flex items-center justify-between text-sm">
                    <span class="font-mono text-gray-500 dark:text-gray-400">{{currency}}</span>
                    <span class="font-semibold text-gray-800 dark:text-gray-200">{{format-currency total currency}}</span>
                </div>
            {{/each-in}}
        {{else}}
            <div class="text-center text-gray-400 py-4 text-sm">No wallet data.</div>
        {{/if}}
    </div>
</div>
