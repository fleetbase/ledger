<div class="p-4 space-y-2">
    {{#if this.loadData.isRunning}}
        <div class="flex items-center justify-center py-6"><Spinner /></div>
    {{else if this.counts}}
        {{#each-in this.counts as |status count|}}
            <div class="flex items-center justify-between text-sm">
                <span class="capitalize text-gray-600 dark:text-gray-400">{{status}}</span>
                <span class="font-semibold text-gray-800 dark:text-gray-200">{{count}}</span>
            </div>
        {{/each-in}}
    {{else}}
        <div class="text-center text-gray-400 py-4">No invoice data.</div>
    {{/if}}
</div>
