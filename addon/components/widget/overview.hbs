<div class="flex flex-col" ...attributes>
    <div class="flex flex-row items-center justify-between px-4 py-2 border dark:border-gray-700 border-gray-200 dark:bg-gray-800 bg-gray-50 rounded-t-lg shadow-sm">
        <span class="text-base font-bold text-black dark:text-gray-100">Financial Overview</span>
    </div>
    <div class="border-x border-b dark:border-gray-700 border-gray-200 rounded-b-lg shadow-sm p-4 grid grid-cols-2 lg:grid-cols-4 gap-4 bg-white dark:bg-gray-900">
        <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
            <span class="text-xs text-gray-500 uppercase tracking-wide">Revenue</span>
            <span class="text-xl font-bold text-green-600">
                {{#if this.loadData.isRunning}}
                    <span class="text-gray-300 dark:text-gray-600">—</span>
                {{else}}
                    {{format-currency (or this.data.kpis.total_revenue.current 0) "USD"}}
                {{/if}}
            </span>
        </div>
        <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
            <span class="text-xs text-gray-500 uppercase tracking-wide">Expenses</span>
            <span class="text-xl font-bold text-red-500">
                {{#if this.loadData.isRunning}}
                    <span class="text-gray-300 dark:text-gray-600">—</span>
                {{else}}
                    {{format-currency (or this.data.kpis.total_expenses.current 0) "USD"}}
                {{/if}}
            </span>
        </div>
        <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
            <span class="text-xs text-gray-500 uppercase tracking-wide">Net Income</span>
            <span class="text-xl font-bold text-blue-600">
                {{#if this.loadData.isRunning}}
                    <span class="text-gray-300 dark:text-gray-600">—</span>
                {{else}}
                    {{format-currency (or this.data.kpis.net_income.current 0) "USD"}}
                {{/if}}
            </span>
        </div>
        <div class="flex flex-col gap-1 p-3 rounded-lg bg-gray-50 dark:bg-gray-800">
            <span class="text-xs text-gray-500 uppercase tracking-wide">Outstanding AR</span>
            <span class="text-xl font-bold text-yellow-600">
                {{#if this.loadData.isRunning}}
                    <span class="text-gray-300 dark:text-gray-600">—</span>
                {{else}}
                    {{format-currency (or this.data.kpis.outstanding_ar.total 0) "USD"}}
                {{/if}}
            </span>
        </div>
    </div>
</div>
