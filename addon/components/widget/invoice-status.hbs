<div class="ledger-dashboard-widget flex h-full flex-col rounded-md border bg-white shadow-sm dark:bg-gray-800" ...attributes>
    <div class="ledger-widget-header">
        <div class="min-w-0">
            <div class="ledger-widget-title">Invoice Pipeline</div>
            <div class="ledger-widget-subtitle">{{or this.data.total_count 0}} invoices · open balance tracked by status</div>
        </div>
        <button type="button" class="ledger-icon-button" {{on "click" (perform this.load)}}><FaIcon @icon="rotate" /></button>
    </div>

    <div class="ledger-widget-body">
        {{#if this.error}}
            <div class="ledger-widget-empty">{{this.error}}</div>
        {{else if this.load.isRunning}}
            <div class="ledger-widget-empty"><Spinner /></div>
        {{else if this.hasData}}
            <div class="ledger-animated-list space-y-3">
                {{#each this.statusRows as |row|}}
                    <div class="ledger-animated-row ledger-status-row">
                        <div class="flex items-center justify-between gap-3 text-xs">
                            <span class="font-semibold capitalize text-gray-700 dark:text-gray-200">{{row.status}}</span>
                            <span class="text-gray-500 dark:text-gray-400">{{row.count}}</span>
                        </div>
                        <div class="ledger-progress-track">
                            <div class="ledger-progress-bar ledger-status-{{row.status}}" style={{html-safe (concat "width: " row.pct "%")}}></div>
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="ledger-widget-empty">No invoices yet.</div>
        {{/if}}
    </div>
</div>
