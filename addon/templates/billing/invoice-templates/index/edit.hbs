<EmberWormhole @to="ledger-template-builder-outlet">
    <TemplateBuilder
        @template={{this.template}}
        @contextSchemas={{this.contextSchemas}}
        @isSaving={{this.save.isRunning}}
        @onSave={{perform this.save}}
        @onPreview={{perform this.preview}}
        @onClose={{this.close}}
    />
</EmberWormhole>
