<Layout::Resource::Panel
    @resource={{this.invoice}}
    @controller={{this}}
    @headerTitle="Create New Invoice"
    @actionButtons={{this.actionButtons}}
    @saveTask={{this.save}}
    @onPressCancel={{transition-to "billing.invoices.index"}}
    @onOverlayReady={{fn (mut this.overlay)}}
>
    <Invoice::Form @resource={{this.invoice}} @controller={{this}} />
    <Spacer @height="200px" />
</Layout::Resource::Panel>
