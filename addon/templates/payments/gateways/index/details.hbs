<div class="h-full overflow-y-auto bg-gray-50 dark:bg-gray-900">
    <div class="flex w-full flex-col">
        <section class="sticky top-0 z-50 bg-white pt-4 shadow-sm dark:bg-gray-900">
            <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 lg:flex-row lg:items-start lg:justify-between md:px-6">
                <div class="flex min-w-0 items-start gap-3">
                    <div class="mt-1 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-md border border-gray-200 bg-gray-50 text-gray-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100">
                        <FaIcon @icon={{this.driverIcon}} />
                    </div>
                    <div class="min-w-0">
                        <div class="flex flex-wrap items-center gap-2">
                            <h1 class="truncate text-lg font-bold text-gray-900 dark:text-gray-100">{{or @model.name @model.driver}}</h1>
                            <Badge @status={{@model.status}} @hideStatusDot={{true}}>{{this.statusLabel}}</Badge>
                            <Badge @color={{if (eq @model.environment "live") "success" "warning"}}>{{titleize @model.environment}}</Badge>
                        </div>
                        <div class="mt-1 text-sm text-gray-500 dark:text-gray-300">
                            {{titleize @model.driver}}
                            {{#if @model.public_id}}
                                <span class="mx-1 text-gray-300 dark:text-gray-600">/</span>
                                <span class="font-mono text-xs">{{@model.public_id}}</span>
                            {{/if}}
                        </div>
                        <div class="mt-2 flex flex-wrap gap-2 text-xs text-gray-500 dark:text-gray-300">
                            <span>Webhook: {{if @model.webhook_url "configured" "not registered"}}</span>
                            <span>Created: {{n-a @model.createdAtShort}}</span>
                            <span>Updated: {{n-a @model.updatedAtShort}}</span>
                        </div>
                    </div>
                </div>

                <div class="flex flex-shrink-0 flex-nowrap items-center gap-2 whitespace-nowrap">
                    <Button @icon="arrow-left" @text="Back" @size="xs" @onClick={{transition-to "payments.gateways.index"}} />
                    <Button @icon="cog" @text="Settings" @size="xs" @onClick={{this.editGateway}} />
                    <Button @icon="trash" @text="Delete" @type="danger" @size="xs" @onClick={{this.deleteGateway}} />
                </div>
            </div>

            <nav class="mt-4 flex w-full gap-1 overflow-x-auto border-b border-gray-200 text-sm dark:border-gray-700" aria-label="Gateway sections">
                <LinkTo
                    @route="payments.gateways.index.details.setup"
                    class="inline-flex flex-shrink-0 items-center border-b-2 border-transparent px-3 py-3 font-medium text-gray-500 hover:border-blue-400 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
                >
                    Overview
                </LinkTo>
                <LinkTo
                    @route="payments.gateways.index.details.diagnostics"
                    class="inline-flex flex-shrink-0 items-center border-b-2 border-transparent px-3 py-3 font-medium text-gray-500 hover:border-blue-400 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
                >
                    Setup
                </LinkTo>
                <LinkTo
                    @route="payments.gateways.index.details.index"
                    class="inline-flex flex-shrink-0 items-center border-b-2 border-transparent px-3 py-3 font-medium text-gray-500 hover:border-blue-400 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
                >
                    Diagnostics
                </LinkTo>
                <LinkTo
                    @route="payments.gateways.index.details.webhooks"
                    class="inline-flex flex-shrink-0 items-center border-b-2 border-transparent px-3 py-3 font-medium text-gray-500 hover:border-blue-400 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white"
                >
                    Transactions
                </LinkTo>
            </nav>
        </section>

        <section class="mx-auto w-full max-w-7xl min-w-0 px-4 py-4 md:px-6">
            {{outlet}}
        </section>
    </div>
</div>
