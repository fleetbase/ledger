<Layout::Resource::Panel
    @title={{@model.gateway_transaction_id}}
    @onClose={{route-action "transitionTo" "console.ledger.payments.transactions.index"}}
>
    <:header>
        <Transaction::PanelHeader @transaction={{@model}} />
    </:header>
    <:default>
        <TabNavigation @tabs={{this.tabs}}>
            <:default>
                {{outlet}}
            </:default>
        </TabNavigation>
    </:default>
</Layout::Resource::Panel>
