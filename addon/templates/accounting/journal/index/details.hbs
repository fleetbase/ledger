<Layout::Resource::Panel
    @title={{@model.number}}
    @actionButtons={{this.actionButtons}}
    @onClose={{route-action "transitionTo" "console.ledger.accounting.journal.index"}}
>
    <:header>
        <Journal::PanelHeader @entry={{@model}} />
    </:header>
    <:default>
        <TabNavigation @tabs={{this.tabs}}>
            <:default>
                {{outlet}}
            </:default>
        </TabNavigation>
    </:default>
</Layout::Resource::Panel>
